# ============================================
# PHISHWISE ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ============================================
# DATABASE (Required)
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/phishwise"

# ============================================
# NEXTAUTH - OAuth & Sessions
# ============================================
# For local development: http://localhost:3000
# For Vercel: Leave this as-is, Vercel will set it automatically per deployment
# DO NOT set this on Vercel environment variables - Vercel auto-detects it
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
# Keep this SECRET - same value across all environments for consistency
NEXTAUTH_SECRET="your-32-byte-random-secret-here"

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# EMAIL SERVICE (Choose one)
# ============================================
# Option 1: Resend (recommended for dev)
RESEND_API_KEY="your-resend-api-key"

# Option 2: SendGrid (for production)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# ============================================
# SCHEDULER
# ============================================
# Generate a random secret: openssl rand -base64 32
SCHEDULER_SECRET="your-strong-scheduler-secret"
ENABLE_SCHEDULER="false"

# ============================================
# ADMIN SETTINGS
# ============================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS="phishwise0@gmail.com"
