# ============================================
# PHISHWISE ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ============================================
# ENVIRONMENT
# ============================================
# Controls which database and features are used
# Options: development, staging, production
ENVIRONMENT="development"

# ============================================
# DATABASE (Required)
# ============================================
# The project auto-detects and connects to the right database:
# - Production (main branch) → PRISMA_DATABASE_URL
# - Staging (branch deployments) → STAGING_PRISMA_DATABASE_URL
# - Development (local) → PRISMA_DATABASE_URL

# For local development with Vercel Postgres:
# Copy PRISMA_DATABASE_URL from: Vercel Dashboard → Environment Variables
DATABASE_URL="postgresql://user:password@host.vercel-storage.com:..."

# Production database - created by Vercel Prisma Postgres
# Auto-selected when ENVIRONMENT=production
# PRISMA_DATABASE_URL="postgresql://default:password@host.vercel-storage.com:5432/verceldb?pgbouncer=true&connect_timeout=15"

# Staging database - created by Vercel Prisma Postgres
# Auto-selected when ENVIRONMENT=staging
# STAGING_PRISMA_DATABASE_URL="postgresql://default:password@host.vercel-storage.com:5432/verceldb?pgbouncer=true&connect_timeout=15"

# ============================================
# NEXTAUTH - OAuth & Sessions
# ============================================
# For local development: http://localhost:3000
# For Vercel: Leave this as-is, Vercel will set it automatically per deployment
# DO NOT set this on Vercel environment variables - Vercel auto-detects it
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
# Different value per environment (prod vs staging)
NEXTAUTH_SECRET="your-32-byte-random-secret-here"

# ============================================
# GOOGLE OAUTH 2.0
# ============================================
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Same for all environments (uses wildcard redirect URIs)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# EMAIL SERVICE (Choose one)
# ============================================
# Option 1: Resend (recommended for dev)
RESEND_API_KEY="your-resend-api-key"

# Option 2: SendGrid (for production)
# SENDGRID_API_KEY="your-sendgrid-api-key"

# ============================================
# SCHEDULER
# ============================================
# Generate a random secret: openssl rand -base64 32
# Different value per environment (prod vs staging)
SCHEDULER_SECRET="your-strong-scheduler-secret"

# ============================================
# ADMIN SETTINGS
# ============================================
# Comma-separated list of admin email addresses
ADMIN_EMAILS="phishwise0@gmail.com"
