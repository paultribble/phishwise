generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth uses JWT strategy — no database sessions needed

// ============================================
// PhishWise Core Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // PhishWise specific
  role           Role      @default(USER)
  schoolId       String?
  lastSimulation DateTime?
  unsubscribedAt            DateTime?
  simulationFrequencyOverride String?

  // Relations
  school          School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  simulations     SimulationEmail[]
  trainingHistory UserTraining[]
  history         UserHistory[]
  metrics         UserMetrics?

  @@index([email])
  @@index([schoolId])
}

enum Role {
  USER
  MANAGER
  ADMIN
}

model School {
  id              String   @id @default(cuid())
  name            String
  inviteCode      String   @unique
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  frequency       String   @default("weekly")
  enableScheduler Boolean  @default(true)
  cronExpression  String?

  users     User[]
  campaigns Campaign[]

  @@index([inviteCode])
}

model TrainingModule {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  content     String   @db.Text
  orderIndex  Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templates    Template[]
  userProgress UserTraining[]

  @@index([isActive])
  @@index([orderIndex])
}

model Template {
  id          String   @id @default(cuid())
  moduleId    String
  name        String
  subject     String
  body        String   @db.Text
  fromAddress String?  @default("security@verify-account.com")
  difficulty  Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module      TrainingModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  simulations SimulationEmail[]

  @@index([moduleId])
  @@index([isActive])
  @@index([difficulty])
}

model SimulationEmail {
  id            String    @id @default(cuid())
  trackingToken String    @unique @default(cuid())
  sentAt        DateTime  @default(now())
  opened        Boolean   @default(false)
  openedAt      DateTime?
  clicked       Boolean   @default(false)
  clickedAt     DateTime?
  status        String    @default("sent")

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateId])
  @@index([trackingToken])
  @@index([sentAt])
}

model UserTraining {
  id          String    @id @default(cuid())
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  score       Int?

  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId String
  module   TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  scheduleType String   @default("random")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schoolId    String?
  school      School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  simulations SimulationEmail[]

  @@index([schoolId])
  @@index([status])
}

model UserMetrics {
  id             String    @id @default(cuid())
  userId         String    @unique
  totalSent      Int       @default(0)
  totalClicked   Int       @default(0)
  totalCompleted Int       @default(0)
  lastActivity   DateTime?
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserHistory {
  id         String   @id @default(cuid())
  userId     String
  actionType String
  detail     String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
}

// One-time tokens for password reset ("reset") and magic link sign-in ("magic")
model AuthToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  type      String    // "reset" | "magic"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}
